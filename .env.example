# ── DocChat Environment Configuration (Ollama) ────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Required ───────────────────────────────────────────────────────

# Ollama base URL (default is localhost)
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional ───────────────────────────────────────────────────────

# ChromaDB telemetry (set to False to disable)
# ANONYMIZED_TELEMETRY=False

# HuggingFace token for gated models (only needed if you change
# EMBEDDING_MODEL or RERANKER_MODEL in src/settings.py to a gated model)
# HF_TOKEN=hf_your_token_here

# User agent string for outbound HTTP requests (optional)
# USER_AGENT=DocChat/1.0
