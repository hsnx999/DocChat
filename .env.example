# ── DocChat Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Ollama (Local) ─────────────────────────────────────────────────

# Ollama base URL (default is localhost)
# OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI ─────────────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Anthropic Claude ───────────────────────────────────────────────
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── DeepSeek ───────────────────────────────────────────────────────
# Get a key at https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...

# ── Google Gemini ──────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# ── Groq (Free Tier) ─────────────────────────────────────────────────
# Get a key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# ── OpenCode Zen ─────────────────────────────────────────────────────
# Get a key at https://opencode.ai/auth
# OPENCODE_API_KEY=z_...

# ── Optional ───────────────────────────────────────────────────────

# ChromaDB telemetry (set to False to disable)
# ANONYMIZED_TELEMETRY=False

# HuggingFace token for gated models (only needed if you change
# EMBEDDING_MODEL or RERANKER_MODEL in src/settings.py to a gated model)
# HF_TOKEN=hf_your_token_here

# User agent string for outbound HTTP requests (optional)
# USER_AGENT=DocChat/1.0
